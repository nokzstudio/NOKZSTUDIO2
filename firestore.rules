rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      let email = request.auth.token.get('email', '').lower();
      return isSignedIn() && (
        email == "nokzdesign.inc@gmail.com" || 
        email == "nokzdesign@gmail.com"
      );
    }

    // Specific collection rules
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']));
    }

    match /orders/{orderId} {
      allow read, write: if true; 
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /analytics/{monthId} {
      allow read, write: if true;
    }

    // Default deny (last resort)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
